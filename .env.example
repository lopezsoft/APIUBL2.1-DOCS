# ============================================================================
# .env.example - Plantilla de Configuración
# Copiar a .env.local (desarrollo) o .env.production (producción)
# ============================================================================

# ============================================================================
# Backend Configuration
# ============================================================================
REACT_APP_API_BACKEND=http://localhost:3001
REACT_APP_API_CHAT_ENDPOINT=/api/ai/chat
REACT_APP_API_SEARCH_ENDPOINT=/api/ai/search
REACT_APP_API_DOCS_ENDPOINT=/api/ai/docs
REACT_APP_API_HEALTH_CHECK=/api/health
REACT_APP_API_TIMEOUT=30000

# ============================================================================
# Application Configuration
# ============================================================================
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001
APP_NAME=MATIAS API Documentation
APP_VERSION=1.4.0

# ============================================================================
# OpenAI Configuration
# ============================================================================
OPENAI_API_KEY=sk-proj-YOUR_API_KEY_HERE
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============================================================================
# Chat Configuration
# ============================================================================
CHAT_MAX_HISTORY=20
CHAT_TIMEOUT=30000
CHAT_MAX_TOKENS=4000
CHAT_CONTEXT_SIZE=10

# ============================================================================
# Caching Configuration
# ============================================================================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_TYPE=memory

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=text

# ============================================================================
# Security Configuration
# ============================================================================
SECURITY_HELMET_ENABLED=true
SECURITY_RATE_LIMIT_ENABLED=false
JWT_SECRET=your-secret-key-change-this

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_AI_SEARCH=true
FEATURE_AI_CHAT=true
FEATURE_DOCUMENTATION_EXPORT=true
FEATURE_ANALYTICS=false
FEATURE_ADVANCED_FILTERING=true
