# Configuración del Backend OpenAI API (Desarrollo)
# Este archivo es para desarrollo local (.env.local)
# Para producción, crea .env.production con tus valores

# URL del servidor backend
REACT_APP_API_BACKEND=http://localhost:3001

# URL del endpoint de chat
REACT_APP_API_CHAT_ENDPOINT=/api/openai/chat

# URL del health check
REACT_APP_API_HEALTH_CHECK=/health

# Timeout para requests (ms)
REACT_APP_API_TIMEOUT=30000

# OpenAI API Key (solo para backend)
OPENAI_API_KEY=sk-proj-tu-clave-aqui

# Puerto del backend
PORT=3001
