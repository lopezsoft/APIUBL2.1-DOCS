# Configuración del Backend OpenAI API (Producción)
# Este archivo es un template para producción (.env.production)
# Copia este archivo a .env.production y llena tus valores reales

# URL del servidor backend (producción)
REACT_APP_API_BACKEND=https://api.matias-api.com

# URL del endpoint de chat
REACT_APP_API_CHAT_ENDPOINT=/api/openai/chat

# URL del health check
REACT_APP_API_HEALTH_CHECK=/health

# Timeout para requests (ms)
REACT_APP_API_TIMEOUT=30000

# OpenAI API Key (solo para backend)
OPENAI_API_KEY=sk-proj-tu-clave-aqui

# Puerto del backend
PORT=443
